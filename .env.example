# Google Gemini API key — tạo miễn phí tại https://aistudio.google.com/apikey
# Local: copy file này thành .env.local rồi điền key
# Vercel: thêm vào Project Settings -> Environment Variables
GEMINI_API_KEY=your-gemini-api-key

# (Tuỳ chọn) Nhiều key dự phòng, phân tách bằng dấu phẩy — nếu key đang dùng bị lỗi/hết quota,
# app sẽ tự động thử key tiếp theo trong danh sách. Nếu đặt biến này thì GEMINI_API_KEY ở trên bị bỏ qua.
# GEMINI_API_KEYS=key-1,key-2,key-3

# (Tuỳ chọn) Đổi model nếu muốn, mặc định gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# Đăng nhập app (chỉ 1 người dùng, không cần database).
# Tự chọn 1 username/password bất kỳ rồi điền vào đây (và vào Vercel Environment Variables khi deploy).
APP_USERNAME=your-username
APP_PASSWORD=your-password
