# Gemini API key — lấy miễn phí tại https://aistudio.google.com/apikey
# Local: copy file này thành .env.local rồi điền key
# Vercel: thêm vào Project Settings -> Environment Variables
GEMINI_API_KEY=your-gemini-api-key

# Đăng nhập app (chỉ 1 người dùng, không cần database).
# Tự chọn 1 username/password bất kỳ rồi điền vào đây (và vào Vercel Environment Variables khi deploy).
APP_USERNAME=your-username
APP_PASSWORD=your-password
