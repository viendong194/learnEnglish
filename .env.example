# OpenRouter API key — tạo tại https://openrouter.ai/settings/keys
# Local: copy file này thành .env.local rồi điền key
# Vercel: thêm vào Project Settings -> Environment Variables
OPENROUTER_API_KEY=your-openrouter-api-key

# (Tuỳ chọn) Model dùng cho hội thoại — mặc định google/gemini-2.5-flash.
# Có thể đổi sang model khác trên openrouter.ai/models, ví dụ model miễn phí có hậu tố :free
# OPENROUTER_MODEL=google/gemini-2.5-flash

# (Tuỳ chọn) Model phân tích video YouTube — PHẢI là model Gemini (chỉ Gemini đọc được YouTube URL)
# OPENROUTER_VIDEO_MODEL=google/gemini-2.5-flash

# Đăng nhập app (chỉ 1 người dùng, không cần database).
# Tự chọn 1 username/password bất kỳ rồi điền vào đây (và vào Vercel Environment Variables khi deploy).
APP_USERNAME=your-username
APP_PASSWORD=your-password
